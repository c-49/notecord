DB_USER=directus
DB_PASSWORD=change_this_password
DB_DATABASE=notecord

# Generate with: openssl rand -hex 32
DIRECTUS_SECRET=replace_with_long_random_secret

ADMIN_EMAIL=admin@notecord.local
ADMIN_PASSWORD=change_this_password

# This token is used by the Vue frontend to authenticate API requests.
# Use the same value in frontend/.env → VITE_DIRECTUS_TOKEN
ADMIN_TOKEN=replace_with_long_random_token
