DB_USER=directus
DB_PASSWORD=change_this_password
DB_DATABASE=notecord

# Generate with: openssl rand -hex 32
DIRECTUS_SECRET=replace_with_long_random_secret

ADMIN_EMAIL=admin@notecord.local
ADMIN_PASSWORD=change_this_password

# This token is used by the Vue frontend to authenticate API requests.
# Use the same value in frontend/.env → VITE_DIRECTUS_TOKEN
ADMIN_TOKEN=replace_with_long_random_token

# Scoped read-only token for a dedicated "asset-reader" service user (created by
# setup-schema.js), used only for file/image URLs — see api.js's getFileUrl().
# This keeps the admin token out of every <img>/<a> src in the DOM.
# Use the same value in frontend/.env → VITE_DIRECTUS_ASSET_TOKEN
ASSET_TOKEN=replace_with_long_random_token

# Real login credentials for the "NoteCord User" role (created by setup-schema.js).
# This is the account the Vue app's login screen actually authenticates as —
# distinct from ADMIN_EMAIL/ADMIN_PASSWORD, which has full Directus admin access.
APP_USER_EMAIL=you@example.com
APP_USER_PASSWORD=change_this_password

# Cookie settings for the httpOnly refresh-token cookie used by the frontend's
# session login. Local dev (frontend/backend both on localhost, same-site):
#   REFRESH_TOKEN_COOKIE_SECURE=false
#   REFRESH_TOKEN_COOKIE_SAME_SITE=lax
# Production (frontend on a Workers domain, backend on a different domain —
# cross-site — and both served over HTTPS):
#   REFRESH_TOKEN_COOKIE_SECURE=true
#   REFRESH_TOKEN_COOKIE_SAME_SITE=none
REFRESH_TOKEN_COOKIE_SECURE=false
REFRESH_TOKEN_COOKIE_SAME_SITE=lax

